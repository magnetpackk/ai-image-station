# AI Image Station - Environment Variables
# Copy this file to .env and fill in your values

# Access code for logging into the web UI
ACCESS_CODE=your-access-code-here

# Server secret for JWT signing (generate with: openssl rand -hex 32)
SERVER_SECRET=your-secret-here

# Public base URL (set to your domain in production)
PUBLIC_BASE_URL=http://localhost:8080

# JWT token TTL in hours
TOKEN_TTL_HOURS=24

# Max upload size in bytes (default 10MB)
MAX_UPLOAD_SIZE=10485760
